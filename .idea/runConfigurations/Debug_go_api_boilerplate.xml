<?xml version="1.0" encoding="UTF-8"?>
<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="Debug go-api-boilerplate" type="GoApplicationRunConfiguration" factoryName="Go Application">

    <!-- Entry point -->
    <module name="go-api-boilerplate" />
    <working_directory value="$PROJECT_DIR$" />
    <filePath value="$PROJECT_DIR$/main.go" />
    <kind value="FILE" />

    <!-- Environment variables for local debug -->
    <envs>
      <env name="TZ" value="Asia/Jakarta" />
    </envs>

    <!--
      Go tool arguments:
        -race   → enables the race detector so concurrent bugs surface early
    -->
    <go_parameters value="-race" />

    <!--
      Program arguments: none required — config is read from appsettings.ini
      Add any flags your config.LoadConfigIni() supports here, e.g.:
        -config ./appsettings.ini
    -->
    <parameters value="" />

    <method v="2" />
  </configuration>
</component>

